{
  "model": {
    "name": "temp_watch",
    "type": "Trained+Anomaly",
    "runtime": "EdgeML",
    "target_core": "Cortex-M33",
    "vendor": "Generic",
    "description": "Simple EIL advisory model for temperature and vibration monitoring"
  },
  "inputs": [
    {
      "channel": "temperature_c",
      "valueType": "numeric",
      "unit": "C",
      "sampleRateHz": 1,
      "scale": 1.0
    },
    {
      "channel": "vibration_g",
      "valueType": "numeric",
      "unit": "g",
      "sampleRateHz": 10,
      "scale": 1.0
    },
    {
      "channel": "cover_open",
      "valueType": "bit",
      "trueLabel": "OPEN",
      "falseLabel": "CLOSED"
    }
  ],
  "outputs": [
    "anomaly_score",
    "advisory_score",
    "alert_state",
    "reason_code"
  ],
  "alertThresholds": {
    "warn": 0.50,
    "fail": 0.80
  },
  "reasonCodes": [
    {
      "key": "NORMAL",
      "message": "System behavior is within expected range"
    },
    {
      "key": "THERMAL_DRIFT",
      "message": "Temperature is rising above expected trend"
    },
    {
      "key": "VIBRATION_HIGH",
      "message": "Vibration is above expected operating range"
    },
    {
      "key": "ACCESS_OPEN",
      "message": "Protective cover is open",
      "forceFail": true
    }
  ]
}
